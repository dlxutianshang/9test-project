<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.usermanagement.mapper.UserPostMapper">

    <select id="countByPostId" resultType="int">
        SELECT COUNT(1) FROM sys_user_post WHERE post_id = #{postId}
    </select>

    <select id="countByPostIds" resultType="int">
        SELECT COUNT(1) FROM sys_user_post WHERE post_id IN
        <foreach collection="postIds" item="postId" open="(" separator="," close=")">
            #{postId}
        </foreach>
    </select>

    <delete id="deleteByPostId">
        DELETE FROM sys_user_post WHERE post_id = #{postId}
    </delete>

    <delete id="deleteByPostIds">
        DELETE FROM sys_user_post WHERE post_id IN
        <foreach collection="postIds" item="postId" open="(" separator="," close=")">
            #{postId}
        </foreach>
    </delete>

    <insert id="batchInsert">
        INSERT INTO sys_user_post (user_id, post_id, create_time) VALUES
        <foreach collection="postIds" item="postId" separator=",">
            (#{userId}, #{postId}, NOW())
        </foreach>
    </insert>

    <select id="selectPostIdsByUserId" resultType="long">
        SELECT post_id FROM sys_user_post WHERE user_id = #{userId}
    </select>
</mapper>
